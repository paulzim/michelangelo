{
  // python
  "python.analysis.extraPaths": [
    "./python"
  ],
  "python.analysis.exclude": [
    "**/.venv/**",
    "**/node_modules/**",
    "**/bazel-*/**",
    "/pkg/**",
    "**/.claude/worktrees/**"
  ],
  // yaml
  "[yaml]": {
    "editor.formatOnSave": false
  },
  // javascript
  "eslint.workingDirectories": [
    "./javascript"
  ],

  // go
  "go.toolsEnvVars": {
    "GOPACKAGESDRIVER": "${workspaceFolder}/tools/gopackagesdriver.sh"
  },
  "go.enableCodeLens": {
    "runtest": false
  },
  "gopls": {
    "build.workspaceFiles": [
      "**/BUILD",
      "**/WORKSPACE",
      "**/*.{bzl,bazel}",
    ],
    "build.directoryFilters": [
      "-bazel-bin",
      "-bazel-out",
      "-bazel-testlogs",
      "-bazel-michelangelo",
    ],
    "formatting.gofumpt": true,
    "formatting.local": "github.com/michelangelo-ai/michelangelo",
    "ui.completion.usePlaceholders": true,
    "ui.semanticTokens": true,
    "ui.codelenses": {
      "gc_details": false,
      "regenerate_cgo": false,
      "generate": false,
      "test": false,
      "tidy": false,
      "upgrade_dependency": false,
      "vendor": false
    },
  },
  "go.useLanguageServer": true,
  "go.buildOnSave": "off",
  "go.lintOnSave": "off",
  "go.vetOnSave": "off",
  // bazel
  "bazel.lsp.command": "bazel-lsp",
}

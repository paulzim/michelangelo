{
  "name": "javascript",
  "engines": {
    "node": "24.14.1",
    "yarn": "^1.22.22"
  },
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "type": "module",
  "scripts": {
    "build": "yarn workspaces run build",
    "dev": "yarn workspace @michelangelo/app dev",
    "dev-production": "yarn workspace @michelangelo-ai/core build && yarn workspace @michelangelo/app dev-production",
    "format": "prettier --check .",
    "generate": "../tools/gen-grpc-client.sh --clients javascript",
    "lint": "eslint . --cache",
    "prebuild": "yarn generate",
    "setup": "yarn install --frozen-lockfile && yarn generate",
    "typecheck": "tsc -b && tsc --project tsconfig.vitest.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:core": "vitest --project=core",
    "test:rpc": "vitest --project=rpc"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-baseui": "^13.0.0",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vitest": "3.2.4"
  },
  "resolutions": {
    "baseui": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "tslib": "^2.6.2",
    "react-uid/tslib": "^1.14.1"
  },
  "resolutionsComments": {
    "tslib": "Required to fix 'Cannot destructure property __extends of import_tslib.default' error that occurs with BaseUI 15 and its dependencies",
    "react-uid/tslib": "react-uid@2.3.0 (used by BaseUI) requires tslib v1.x API while CodeMirror packages require v2.x - force v1 for react-uid specifically"
  }
}

def _parse_input_schema(model_path):
    """Parse input schema from config.pbtxt (one directory up from the version dir)."""
    try:
        with open(os.path.join(model_path, "..", "config.pbtxt")) as f:
            lines = [line.strip() for line in f]
    except OSError:
        return []

    # Find the start of the input section
    start = next((i for i, l in enumerate(lines) if re.match(r"^input\s*:", l)), None)
    if start is None:
        return []

    inputs, block = [], None
    for line in lines[start + 1:]:
        if line in ("{", "["):
            block = {}
        elif line in ("}", "},"):
            if block and "name" in block and "dtype" in block:
                inputs.append(block)
            block = None
        elif line == "]":
            break
        elif block is not None:
            if m := re.match(r'name\s*:\s*"([^"]+)"', line):
                block["name"] = m.group(1)
            elif m := re.match(r"data_type\s*:\s*(\w+)", line):
                block["dtype"] = m.group(1)
            elif m := re.search(r"dims\s*:\s*\[([^\]]*)\]", line):
                block["dims"] = [int(v) for v in re.findall(r"-?\d+", m.group(1))]
    return inputs


